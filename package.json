{
  "name": "hivobu",
  "version": "0.1.0",
  "description": "",
  "license": "ISC",
  "author": "Jean-Philippe Pellet",
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "compile-watch": "tsc -p tsconfig.json --watch",
    "bundle": "./tools/build.js",
    "bundle-watch": "npm-watch bundle",
    "deploy": "./tools/deploy-jpp.sh",
    "server": "./tools/local_server.py 8089"
  },
  "watch": {
    "bundle": {
      "patterns": [
        "web",
        "img"
      ],
      "extensions": "ts,svg"
    },
    "testfiles": {
      "patterns": [
        "sample_src"
      ],
      "extensions": "py"
    }
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "esbuild": "^0.27.3",
    "npm-watch": "^0.13.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "lz-string": "^1.5.0"
  }
}
